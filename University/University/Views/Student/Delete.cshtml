@model University.ViewModel.StudentDeleteViewModel
@{
    ViewData["Title"] = "Delete Student";
}

<h1>Delete Student</h1>

<div class="alert alert-danger">
    <strong>Are you sure you want to delete this student?</strong>
</div>

<dl class="row">
    <dt class="col-sm-3">Last Name</dt>
    <dd class="col-sm-9">@Model.LastName</dd>

    <dt class="col-sm-3">First Name</dt>
    <dd class="col-sm-9">@Model.FirstMidName</dd>

    <dt class="col-sm-3">Enrollment Date</dt>
    <dd class="col-sm-9">@Model.EnrollmentDate.ToShortDateString()</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>